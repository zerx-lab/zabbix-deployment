FROM oven/bun:1-alpine

WORKDIR /app

# Install system dependencies needed for development
RUN apk add --no-cache \
    git \
    docker-cli \
    docker-cli-compose \
    curl \
    bash

# Copy source code (node_modules mounted from host via docker-compose)
COPY . .

# Default command: start dev mode
CMD ["bun", "run", "dev"]
